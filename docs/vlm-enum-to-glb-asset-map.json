  "semantic_to_asset_guidance": {
    "required_asset_tags": "skin_texture, eye_texture, mouth_texture, hair_mesh, top_mesh, bottom_mesh, outfit_mesh, and shoe_mesh must always choose the nearest available semantic tag. Use outfit_mesh none unless a one-piece/dress is visible. Do not output unknown for these. skin_texture must be exactly one of soft_peach_skin or light_warm_skin. Unity derives unity_body_variant from top_mesh and bottom_mesh.",
    "optional_asset_tags": "glasses_mesh, necklace_mesh, and earring_mesh may use none when not visible.",
