LLM_API_KEY=change-me
LLM_SERVER_URL=http://127.0.0.1:18200
LLM_SERVER_API_KEY=change-me
TUTORIAL_APPEARANCE_MODEL=gemma4:e4b
TUTORIAL_APPEARANCE_TEXT_MODEL=gemma4:e4b
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=terarium_memory
POSTGRES_USER=terarium
POSTGRES_PASSWORD=change-me
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECT_TIMEOUT_MS=5000
PORT=8787

# Local/dev escape hatches. Keep false in normal production.
SKIP_TUTORIAL_SCHEMA=false
ALLOW_DUPLICATE_NICKNAME=false

# Optional persona indexing script controls.
NEMOTRON_CONFIG=default
NEMOTRON_SPLIT=train
NEMOTRON_LIMIT=1000
NEMOTRON_OFFSET=0
NEMOTRON_PAGE_SIZE=100
NEMOTRON_PAGE_DELAY_MS=0
NEMOTRON_RETRY_DELAY_MS=10000
